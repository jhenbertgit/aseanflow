{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "ES6"
    ],
    "types": [],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@aseanflow/ui": [
        "./packages/ui/src"
      ],
      "@aseanflow/ui/*": [
        "./packages/ui/src/*"
      ],
      "@aseanflow/shared": [
        "./packages/shared/src"
      ],
      "@aseanflow/shared/*": [
        "./packages/shared/src/*"
      ],
      "@aseanflow/database": [
        "./packages/database/src"
      ],
      "@aseanflow/database/*": [
        "./packages/database/src/*"
      ],
      "@aseanflow/auth": [
        "./packages/auth/src"
      ],
      "@aseanflow/auth/*": [
        "./packages/auth/src/*"
      ],
      "@aseanflow/redis": [
        "./packages/redis/src"
      ],
      "@aseanflow/redis/*": [
        "./packages/redis/src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
{
  "extends": "@aseanflow/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": [],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@aseanflow/ui": [
        "../../packages/ui/src"
      ],
      "@aseanflow/shared": [
        "../../packages/shared/src"
      ],
      "@aseanflow/auth": [
        "../../packages/auth/src"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tests/**/*"
  ]
}
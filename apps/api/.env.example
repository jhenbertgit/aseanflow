# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/aseanflow_dev

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# FX Rates (optional — falls back to hardcoded rates)
APILAYER_API_KEY=

# Morph L2 (for AFT balance lookups)
MORPH_RPC_URL=https://rpc-hoodi.morph.network
MORPH_CHAIN_ID=2910

# ERC-20 Reward Token (AFT) — must match worker config
REWARD_TOKEN_ADDRESS=

# Wallet encryption (32 bytes = 64 hex chars for AES-256-CBC)
WALLET_ENCRYPTION_KEY=

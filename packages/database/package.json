{
  "name": "@aseanflow/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate": "prisma generate",
    "push": "prisma db push",
    "migrate": "prisma migrate dev",
    "studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^16.4.7",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@aseanflow/eslint-config": "workspace:*",
    "@aseanflow/tsconfig": "workspace:*",
    "@types/node": "^20.0.0",
    "globals": "^15.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}

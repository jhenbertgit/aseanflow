generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Currency {
  PHP
  IDR
}

enum TransferStatus {
  CREATED
  QUOTE_LOCKED
  INSTA_PAY_PROCESSING
  FX_CONVERSION
  BI_FAST_PROCESSING
  SETTLED
  MORPH_ANCHORED
}

enum RecipientType {
  WALLET
  BANK
}

model Transfer {
  id             String         @id @default(cuid())
  trackingCode   String         @unique

  sourceCurrency Currency
  targetCurrency Currency

  sendAmount     Decimal        @db.Decimal(18, 2)
  receiveAmount  Decimal        @db.Decimal(18, 2)
  exchangeRate   Decimal        @db.Decimal(18, 6)
  fee            Decimal        @db.Decimal(18, 2)

  status         TransferStatus

  morphTxHash    String?
  instapayRef    String?
  bifastRef      String?

  recipientType     RecipientType @default(WALLET)
  recipientName     String?
  recipientBank     String?
  recipientAccount  String?
  recipientWalletId String?

  senderId       String?
  walletId       String?
  rewardTxHash   String?
  rewardAmount   Decimal?       @db.Decimal(48, 18)

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  sender         User?          @relation(fields: [senderId], references: [id])
  ledgerEntries  LedgerEntry[]
  rewardWallet   RewardWallet?  @relation(fields: [walletId], references: [id])

  @@index([trackingCode])
  @@index([senderId])
  @@map("transfers")
}

model LedgerEntry {
  id         String   @id @default(cuid())
  transferId String
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  debit      Decimal  @db.Decimal(18, 2)
  credit     Decimal  @db.Decimal(18, 2)

  currency   Currency

  createdAt  DateTime @default(now())

  @@index([transferId])
  @@map("ledger_entries")
}

model User {
  id            String   @id @default(cuid())
  accountNumber String   @unique
  name          String
  email         String   @unique
  cookieToken   String   @unique
  createdAt     DateTime @default(now())

  wallets    AccountWallet[]
  transfers  Transfer[]

  @@map("users")
}

model AccountWallet {
  id        String   @id @default(cuid())
  userId    String
  currency  Currency
  balance   Decimal  @db.Decimal(18, 2) @default("0.00")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, currency])
  @@map("account_wallets")
}

model RewardWallet {
  id                  String     @id @default(cuid())
  address             String     @unique
  encryptedPrivateKey String
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  transfers           Transfer[]

  @@index([address])
  @@map("reward_wallets")
}

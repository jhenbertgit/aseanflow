# ASEANFlow — Production Environment
# Copy to .env and fill in values before `docker compose up`

# ── PostgreSQL ──
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=aseanflow
POSTGRES_PORT=5432

# ── Redis ──
REDIS_PORT=6379

# ── Traefik Routing ──
API_HOST=api.yourdomain.com
WEB_HOST=yourdomain.com

# ── API ──
FRONTEND_URL=https://yourdomain.com
LOG_LEVEL=info
APILAYER_API_KEY=
REWARD_TOKEN_ADDRESS=
WALLET_ENCRYPTION_KEY=
REWARD_FEE_DISCOUNT_THRESHOLD=100
REWARD_FEE_DISCOUNT_PERCENT=50

# ── Morph L2 (API + Worker) ──
MORPH_RPC_URL=https://rpc-hoodi.morph.network
MORPH_CHAIN_ID=2910
MORPH_PRIVATE_KEY=

# ── Worker ──
DEPLOYER_PRIVATE_KEY=
REWARD_AMOUNT=10000000000000000000

# ── Web (Next.js) ──
API_BASE_URL=https://api.yourdomain.com
